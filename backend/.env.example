# ─────────────────────────────────────────────────────────────────────
# .env.example — copy this to .env and fill in your real values.
# The .env file is listed in .gitignore and must NEVER be committed.
# ─────────────────────────────────────────────────────────────────────

# Application
APP_NAME="Legacy Code Migration Backend"
APP_VERSION="0.1.0"
DEBUG=False

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite:///./migration.db

# LLM — OpenAI (replace with your real key)
OPENAI_API_KEY=sk-...your-key-here...
OPENAI_MODEL=gpt-4.1

# LLM — Anthropic (optional; required when selecting Anthropic provider)
ANTHROPIC_API_KEY=sk-ant-...your-key-here...
ANTHROPIC_MODEL=claude-opus-4-5

# LLM tuning
MAX_YAML_RETRY_ATTEMPTS=3
MAX_CODE_RETRY_ATTEMPTS=2
LLM_TIMEOUT_SECONDS=60

# CORS — add your frontend origin(s)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=INFO
